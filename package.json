{
	"name": "openboot-web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run && vitest run --config vitest.workers.config.ts",
		"test:ui": "vitest --ui",
		"test:run": "vitest run && vitest run --config vitest.workers.config.ts",
		"test:happy-dom": "vitest run",
		"test:workers": "vitest run --config vitest.workers.config.ts",
		"test:coverage": "vitest run --coverage && vitest run --config vitest.workers.config.ts",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"validate": "npm run lint && npm run check && npm run test:run && npm run build",
		"install:hooks": "node scripts/install-hooks.mjs"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.16.6",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.6",
		"@sveltejs/kit": "^2.50.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@vitest/coverage-v8": "^4.1.6",
		"@vitest/ui": "^4.1.6",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"fuse.js": "^7.1.0",
		"globals": "^15.15.0",
		"happy-dom": "^20.6.1",
		"mdsvex": "^0.12.6",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"rehype-slug": "^6.0.0",
		"shiki": "^3.22.0",
		"svelte": "^5.48.2",
		"svelte-check": "^4.3.5",
		"svelte-eslint-parser": "^1.6.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.59.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.6",
		"wrangler": "^4.61.1"
	},
	"dependencies": {
		"@cf-wasm/resvg": "^0.3.3"
	}
}
